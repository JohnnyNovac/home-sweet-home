{
  "queues": [
    {
      "name": "event-data",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "presence-data",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "device-availability",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "event-data",
      "destination_type": "queue",
      "routing_key": "home.*.*.data",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "presence-data",
      "destination_type": "queue",
      "routing_key": "home.presence.*.data",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "device-availability",
      "destination_type": "queue",
      "routing_key": "home.availability.*",
      "arguments": {}
    }
  ]
}