<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Консоль остаётся в обычном читаемом виде — это дефолтные настройки Spring Boot -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Имя сервиса для метки Loki берём из spring.application.name -->
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <!-- В Loki шлём только в развёрнутом стенде (профиль docker): не локально и не в тестах -->
    <springProfile name="docker">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>http://loki:3100/loki/api/v1/push</url>
            </http>
            <labels>
                source = service
                service = ${appName}
            </labels>
            <!-- Тело лога — обычный читаемый текст; level/logger/thread идут как structured metadata (по умолчанию) -->
            <message>
                <pattern>%-5level %logger{36} - %msg</pattern>
            </message>
        </appender>
    </springProfile>

    <!-- Логи самих сервисов (обработка и передача данных) на уровне DEBUG -->
    <logger name="dev.iot" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <springProfile name="docker">
            <appender-ref ref="LOKI"/>
        </springProfile>
    </root>
</configuration>